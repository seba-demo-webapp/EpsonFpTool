{
  "name": "cassa-rt-epson",
  "productName": "Cassa RT Epson",
  "version": "1.0.0",
  "description": "App di cassa per stampa documenti commerciali su stampante fiscale Epson RT (FP-81 II RT) via FPMate/ePOS.",
  "author": "RT Epson",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --mac",
    "dist:dmg": "electron-builder --mac dmg",
    "dist:win": "electron-builder --win",
    "dist:all": "electron-builder --mac --win"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "it.rtepson.cassa",
    "productName": "Cassa RT Epson",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "renderer/**/*"
    ],
    "mac": {
      "category": "public.app-category.business",
      "target": [
        { "target": "dmg", "arch": ["arm64", "x64"] }
      ],
      "identity": null
    },
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false
    },
    "dmg": {
      "title": "Cassa RT Epson"
    }
  }
}
